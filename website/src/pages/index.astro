---
import DemoUpload from '../components/DemoUpload';
import '../styles/global.css';
const BASE = 'https://pompelmi.github.io/pompelmi';
const TITLE = 'Pompelmi — File upload malware scanning for Node.js (Express, Koa, Next.js) + YARA';
const DESC =
  'Scan and block malicious file uploads in Node.js. Drop-in adapters for Express, Koa, and Next.js. ZIP deep-inspection, MIME & size policies, optional YARA rules.';
const OG_IMAGE = `${BASE}/og.png`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{TITLE}</title>
    <meta name="description" content={DESC} />
    <link rel="canonical" href={BASE + '/'} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index,follow" />
    <meta name="keywords" content="Node.js, Express, Koa, Next.js, file upload, malware scanning, YARA, ZIP bomb, MIME type, security, middleware" />
    <meta name="author" content="Pompelmi" />
    <meta name="theme-color" content="#1d4ed8" />
    <link rel="alternate" hreflang="en" href={BASE + '/'} />
    <link rel="alternate" hreflang="x-default" href={BASE + '/'} />
    <meta property="og:site_name" content="Pompelmi" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Pompelmi — Node.js file upload malware scanning" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={BASE + '/'} />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESC} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESC} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <link rel="icon" href="/pompelmi/favicon.svg" />
    <script defer data-domain="pompelmi.github.io" src="https://plausible.io/js/script.js"></script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "name": "Pompelmi",
            "url": "https://github.com/pompelmi/pompelmi",
            "sameAs": ["https://github.com/pompelmi/pompelmi"]
          },
          {
            "@type": "SoftwareSourceCode",
            "name": "Pompelmi",
            "description": "Scan and block malicious file uploads in Node.js.",
            "programmingLanguage": ["TypeScript", "JavaScript"],
            "runtimePlatform": "Node.js",
            "codeRepository": "https://github.com/pompelmi/pompelmi",
            "license": "https://opensource.org/licenses/MIT"
          },
          {
            "@type": "FAQPage",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "Does Pompelmi support YARA rules?",
                "acceptedAnswer": { "@type": "Answer", "text": "Yes. You can plug in your own YARA rules for advanced detections alongside built-in policies." }
              },
              {
                "@type": "Question",
                "name": "Can it inspect ZIP archives and prevent ZIP bombs?",
                "acceptedAnswer": { "@type": "Answer", "text": "Yes. It enforces limits on entries, per-entry size, total uncompressed size, and nesting depth." }
              },
              {
                "@type": "Question",
                "name": "Which frameworks are supported?",
                "acceptedAnswer": { "@type": "Answer", "text": "Express and Koa middleware, a Next.js App Router handler, and more adapters planned." }
              },
              {
                "@type": "Question",
                "name": "Is commercial support available?",
                "acceptedAnswer": { "@type": "Answer", "text": "Yes. Limited commercial support is available on a private, async, best-effort basis. Email pompelmideveloper@yahoo.com." }
              }
            ]
          }
        ]
      }
    </script>
  </head>

  <body class="antialiased bg-gradient-to-br from-slate-50 via-blue-50/40 to-sky-50/40 min-h-screen">
    <!-- Animated background blobs -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none opacity-20">
      <div class="absolute -top-40 -right-40 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl animate-float" style="animation-delay: 0s;"></div>
      <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-sky-400 rounded-full mix-blend-multiply filter blur-3xl animate-float" style="animation-delay: 2s;"></div>
      <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-80 h-80 bg-blue-300 rounded-full mix-blend-multiply filter blur-3xl animate-float" style="animation-delay: 4s;"></div>
    </div>

    <!-- NAV -->
    <nav class="glass sticky top-0 z-50 shadow-lg">
      <div class="mx-auto max-w-6xl px-6 py-4 flex justify-between items-center">
        <a href="/pompelmi/" class="text-2xl font-bold text-gradient">Pompelmi</a>
        <div class="flex gap-6 text-sm font-semibold items-center">
          <a href="/pompelmi/getting-started/" class="hover:text-blue-600 transition-colors duration-200">Docs</a>
          <a href="/pompelmi/blog/" class="hover:text-blue-600 transition-colors duration-200">Blog</a>
          <a href="/pompelmi/support/" class="inline-flex items-center gap-1.5 bg-blue-600 text-white px-4 py-1.5 rounded-full text-xs font-bold hover:bg-blue-700 transition-colors duration-200 shadow-md">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            Support
          </a>
          <a href="https://github.com/pompelmi/pompelmi" target="_blank" rel="noopener" class="hover:text-blue-600 transition-colors duration-200 flex items-center gap-1.5">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <header class="relative mx-auto max-w-6xl px-6 py-20 md:py-28">
      <div class="text-center relative z-10">
        <div class="inline-block mb-6 px-4 py-2 rounded-full glass text-sm font-semibold text-blue-600 border border-blue-200">
          ✨ Secure File Uploads for Node.js
        </div>
        <h1 class="text-6xl md:text-7xl lg:text-8xl font-extrabold tracking-tight mb-6">
          <span class="block text-gradient animate-glow">Pompelmi</span>
          <span class="block text-4xl md:text-5xl lg:text-6xl mt-4 text-gray-800">File Upload Security</span>
        </h1>
        <p class="mt-6 text-xl md:text-2xl text-gray-600 max-w-4xl mx-auto leading-relaxed font-light">
          {DESC}
        </p>

        <!-- install snippet -->
        <div class="mt-8 inline-flex items-center gap-3 glass rounded-xl px-6 py-3 border border-blue-100 font-mono text-sm text-gray-700">
          <span class="text-blue-400 select-none">$</span>
          <span>npm install pompelmi</span>
          <button
            onclick="navigator.clipboard.writeText('npm install pompelmi')"
            class="ml-2 text-blue-400 hover:text-blue-600 transition-colors"
            title="Copy"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
            </svg>
          </button>
        </div>

        <!-- CTA buttons -->
        <div class="mt-8 flex flex-wrap justify-center items-center gap-4">
          <a
            href="https://github.com/pompelmi/pompelmi?utm_source=site&utm_medium=header_cta&utm_campaign=stars"
            class="group inline-flex items-center gap-3 rounded-xl bg-gradient-to-r from-blue-600 to-sky-500 px-8 py-4 text-white text-lg font-bold shadow-xl hover:shadow-2xl transition-all transform hover:scale-105 animate-glow"
            aria-label="Star Pompelmi on GitHub"
            rel="noopener noreferrer"
            target="_blank"
          >
            <svg class="w-6 h-6 group-hover:rotate-12 transition-transform" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            Star on GitHub
          </a>
          <a
            href="/pompelmi/getting-started/"
            class="inline-flex items-center gap-2 rounded-xl glass px-8 py-4 text-lg font-bold hover:shadow-xl transition-all transform hover:scale-105 border-2 border-blue-200 hover:border-blue-500 text-blue-700"
          >
            Get Started
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
          <a
            href="/pompelmi/support/"
            class="inline-flex items-center gap-2 rounded-xl px-8 py-4 text-lg font-bold border-2 border-blue-600 text-blue-600 hover:bg-blue-600 hover:text-white transition-all transform hover:scale-105"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            Commercial Support
          </a>
        </div>

        <!-- Badges strip -->
        <div class="mt-10 flex flex-wrap justify-center gap-3">
          <a href="https://github.com/pompelmi/pompelmi" target="_blank" rel="noopener" aria-label="GitHub stars">
            <img src="https://img.shields.io/github/stars/pompelmi/pompelmi?style=for-the-badge&logo=github&color=1d4ed8&labelColor=1e3a5f" alt="GitHub stars" loading="lazy" />
          </a>
          <a href="https://www.npmjs.com/package/pompelmi" target="_blank" rel="noopener" aria-label="npm version">
            <img src="https://img.shields.io/npm/v/pompelmi?style=for-the-badge&logo=npm&color=0369a1&labelColor=0c4a6e" alt="npm version" loading="lazy" />
          </a>
          <a href="https://www.npmjs.com/package/pompelmi" target="_blank" rel="noopener" aria-label="npm downloads">
            <img src="https://img.shields.io/npm/dm/pompelmi?style=for-the-badge&logo=npm&color=0284c7&labelColor=0c4a6e&label=downloads%2Fmonth" alt="npm downloads" loading="lazy" />
          </a>
          <a href="https://github.com/pompelmi/pompelmi/blob/main/LICENSE" target="_blank" rel="noopener" aria-label="License">
            <img src="https://img.shields.io/github/license/pompelmi/pompelmi?style=for-the-badge&color=1d4ed8&labelColor=1e3a5f" alt="MIT License" loading="lazy" />
          </a>
          <a href="https://github.com/pompelmi/pompelmi/actions" target="_blank" rel="noopener" aria-label="Build status">
            <img src="https://img.shields.io/github/actions/workflow/status/pompelmi/pompelmi/ci.yml?style=for-the-badge&logo=github-actions&color=0284c7&labelColor=0c4a6e&label=CI" alt="CI status" loading="lazy" />
          </a>
        </div>

        <!-- Feature pills -->
        <div class="mt-12 flex flex-wrap justify-center gap-8 text-sm text-gray-700">
          <div class="flex items-center gap-2 group">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span class="font-semibold">ZIP Bomb Protection</span>
          </div>
          <div class="flex items-center gap-2 group">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-sky-400 to-blue-600 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span class="font-semibold">YARA Integration</span>
          </div>
          <div class="flex items-center gap-2 group">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-500 to-sky-500 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span class="font-semibold">Framework Adapters</span>
          </div>
          <div class="flex items-center gap-2 group">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-600 to-blue-800 flex items-center justify-center shadow-md group-hover:scale-110 transition-transform">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <span class="font-semibold">TypeScript Native</span>
          </div>
        </div>
      </div>
    </header>

    <main class="relative mx-auto max-w-6xl px-6 pb-20">

      <!-- DEMO -->
      <section class="glass rounded-3xl shadow-2xl p-10 md:p-12 border-2 border-blue-100">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-sky-500 flex items-center justify-center">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h2 class="text-4xl font-bold text-gradient">Live Demo</h2>
        </div>
        <p class="text-gray-600 mb-8 text-lg">
          Try uploading files: Clean JPG → <strong class="text-green-600 font-bold">✓ CLEAN</strong>. EICAR test file → <strong class="text-red-600 font-bold">✗ MALICIOUS</strong>.
        </p>
        <DemoUpload client:load />
      </section>

      <!-- FRAMEWORK LOGOS -->
      <section class="mt-24">
        <div class="text-center mb-12">
          <h2 class="text-5xl font-bold text-gradient mb-4">Framework Support</h2>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">Drop-in adapters for your favorite Node.js frameworks</p>
        </div>
        <div class="grid gap-8 md:grid-cols-3">

          <!-- Next.js -->
          <a href="/pompelmi/how-to/nextjs/" class="group glass rounded-3xl p-8 card-hover border-2 border-transparent hover:border-blue-400">
            <div class="w-16 h-16 mb-6 rounded-2xl bg-black flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
              <!-- Next.js logo -->
              <svg class="w-9 h-9 text-white fill-white" viewBox="0 0 180 180">
                <mask id="nxt-mask" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="180" height="180">
                  <circle cx="90" cy="90" r="90" fill="black"/>
                </mask>
                <g mask="url(#nxt-mask)">
                  <circle cx="90" cy="90" r="90" fill="black"/>
                  <path d="M149.508 157.52L69.142 54H54V125.97H66.1755V69.3836L139.999 164.845C143.333 162.614 146.509 160.165 149.508 157.52Z" fill="url(#nxt-grad)"/>
                  <rect x="115" y="54" width="12" height="72" fill="url(#nxt-grad2)"/>
                </g>
                <defs>
                  <linearGradient id="nxt-grad" x1="109" y1="116.5" x2="144.5" y2="160.5" gradientUnits="userSpaceOnUse">
                    <stop stop-color="white"/>
                    <stop offset="1" stop-color="white" stop-opacity="0"/>
                  </linearGradient>
                  <linearGradient id="nxt-grad2" x1="121" y1="54" x2="120.799" y2="106.875" gradientUnits="userSpaceOnUse">
                    <stop stop-color="white"/>
                    <stop offset="1" stop-color="white" stop-opacity="0"/>
                  </linearGradient>
                </defs>
              </svg>
            </div>
            <h3 class="text-2xl font-bold mb-3 text-gray-900 group-hover:text-blue-600 transition-colors">Next.js</h3>
            <p class="text-gray-600 leading-relaxed">Secure file uploads in Next.js App Router with streaming support and server actions.</p>
            <div class="mt-6 inline-flex items-center gap-2 text-blue-600 font-semibold group-hover:gap-4 transition-all">
              Learn more
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </a>

          <!-- Express -->
          <a href="/pompelmi/how-to/express/" class="group glass rounded-3xl p-8 card-hover border-2 border-transparent hover:border-blue-500">
            <div class="w-16 h-16 mb-6 rounded-2xl bg-gray-900 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
              <!-- Express wordmark "e" -->
              <svg class="w-9 h-9" viewBox="0 0 256 256" fill="none">
                <text x="28" y="190" font-family="Arial, sans-serif" font-size="200" font-weight="bold" fill="white">e</text>
              </svg>
            </div>
            <h3 class="text-2xl font-bold mb-3 text-gray-900 group-hover:text-blue-600 transition-colors">Express</h3>
            <p class="text-gray-600 leading-relaxed">Drop-in middleware for Express APIs with seamless Multer integration.</p>
            <div class="mt-6 inline-flex items-center gap-2 text-blue-600 font-semibold group-hover:gap-4 transition-all">
              Learn more
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </a>

          <!-- Koa -->
          <a href="/pompelmi/how-to/koa/" class="group glass rounded-3xl p-8 card-hover border-2 border-transparent hover:border-sky-400">
            <div class="w-16 h-16 mb-6 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
              <!-- Koa leaf icon -->
              <svg class="w-9 h-9 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22l1-2.3A4.49 4.49 0 0 0 8 20C19 20 22 3 22 3c-1 2-8 2-5 8Z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-bold mb-3 text-gray-900 group-hover:text-blue-600 transition-colors">Koa</h3>
            <p class="text-gray-600 leading-relaxed">Lightweight middleware for Koa with modern async/await patterns.</p>
            <div class="mt-6 inline-flex items-center gap-2 text-blue-600 font-semibold group-hover:gap-4 transition-all">
              Learn more
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </a>
        </div>

        <!-- Node.js + npm logo row -->
        <div class="mt-10 flex flex-wrap justify-center items-center gap-6 text-sm text-gray-500">
          <span class="font-medium text-gray-400 uppercase tracking-widest text-xs">Powered by</span>
          <!-- Node.js -->

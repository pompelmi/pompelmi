---
import DemoUpload from '../components/DemoUpload';
import '../styles/global.css';
const BASE = 'https://pompelmi.github.io/pompelmi';
const TITLE = 'Pompelmi — File upload malware scanning for Node.js';
const DESC = 'In-process file upload security for Node.js. No cloud API, no daemon. Drop-in scanning for Express, Next.js, NestJS, Fastify, and Koa.';
const OG_IMAGE = `${BASE}/og.png`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{TITLE}</title>
    <meta name="description" content={DESC} />
    <link rel="canonical" href={BASE + '/'} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index,follow" />
    <meta name="keywords" content="Node.js, Express, Koa, Next.js, NestJS, Fastify, file upload, malware scanning, YARA, ZIP bomb, MIME type, security, middleware" />
    <meta name="author" content="Pompelmi" />
    <meta name="theme-color" content="#0f172a" />
    <link rel="alternate" hreflang="en" href={BASE + '/'} />
    <link rel="alternate" hreflang="x-default" href={BASE + '/'} />
    <meta property="og:site_name" content="Pompelmi" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Pompelmi — Node.js file upload malware scanning" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={BASE + '/'} />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESC} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESC} />
    <meta name="twitter:image" content={OG_IMAGE} />
    <link rel="icon" href="/pompelmi/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script defer data-domain="pompelmi.github.io" src="https://plausible.io/js/script.js"></script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "name": "Pompelmi",
            "url": "https://github.com/pompelmi/pompelmi",
            "sameAs": ["https://github.com/pompelmi/pompelmi"]
          },
          {
            "@type": "SoftwareSourceCode",
            "name": "Pompelmi",
            "description": "In-process file upload security for Node.js.",
            "programmingLanguage": ["TypeScript", "JavaScript"],
            "runtimePlatform": "Node.js",
            "codeRepository": "https://github.com/pompelmi/pompelmi",
            "license": "https://opensource.org/licenses/MIT"
          }
        ]
      }
    </script>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html { font-family: 'Inter', system-ui, sans-serif; }
      body { margin: 0; background: #fff; color: #0f172a; }
      code, .mono { font-family: 'JetBrains Mono', 'Fira Code', monospace; }
      a { color: inherit; text-decoration: none; }
      h1, h2, h3, h4 { margin: 0; font-weight: 700; letter-spacing: -0.02em; }
      p { margin: 0; }
      ul { margin: 0; padding: 0; list-style: none; }

      .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

      /* NAV */
      .nav {
        position: sticky; top: 0; z-index: 50;
        background: rgba(255,255,255,0.92);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid #e2e8f0;
      }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 60px; }
      .nav-logo { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 1.05rem; color: #0f172a; transition: opacity .15s; }
      .nav-logo:hover { opacity: .75; }
      .nav-links { display: flex; align-items: center; gap: 4px; }
      .nav-link { padding: 6px 12px; font-size: .875rem; font-weight: 500; color: #475569; border-radius: 6px; transition: background .15s, color .15s; }
      .nav-link:hover { background: #f1f5f9; color: #0f172a; }
      .nav-link-ent { padding: 6px 14px; font-size: .875rem; font-weight: 600; background: #0f172a; color: #fff; border-radius: 6px; transition: background .15s; }
      .nav-link-ent:hover { background: #1e293b; }
      .nav-gh { display: flex; align-items: center; gap: 6px; padding: 6px 12px; font-size: .875rem; font-weight: 500; color: #475569; border-radius: 6px; transition: background .15s, color .15s; }
      .nav-gh:hover { background: #f1f5f9; color: #0f172a; }

      /* HERO */
      .hero { padding: 96px 0 72px; text-align: center; border-bottom: 1px solid #f1f5f9; }
      .hero-badge { display: inline-flex; align-items: center; gap: 7px; padding: 4px 14px; border: 1px solid #e2e8f0; border-radius: 100px; font-size: .8rem; font-weight: 500; color: #475569; background: #f8fafc; margin-bottom: 28px; }
      .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; }
      .hero-title { font-size: clamp(2.4rem, 6vw, 4.5rem); font-weight: 700; letter-spacing: -.04em; line-height: 1.05; color: #0f172a; margin-bottom: 20px; }
      .hero-sub { font-size: 1.1rem; color: #64748b; max-width: 540px; margin: 0 auto 36px; line-height: 1.7; font-weight: 400; }
      .hero-install { display: inline-flex; align-items: center; gap: 10px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 10px 18px; font-size: .875rem; color: #334155; margin-bottom: 32px; }
      .hero-install .prompt { color: #94a3b8; user-select: none; }
      .copy-btn { background: none; border: none; padding: 0; color: #94a3b8; display: flex; align-items: center; cursor: pointer; transition: color .15s; }
      .copy-btn:hover { color: #2563eb; }
      .hero-ctas { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; }
      .btn-dark { display: inline-flex; align-items: center; gap: 8px; padding: 10px 22px; background: #0f172a; color: #fff; font-size: .9375rem; font-weight: 600; border-radius: 8px; transition: background .15s; }
      .btn-dark:hover { background: #1e293b; }
      .btn-outline { display: inline-flex; align-items: center; gap: 8px; padding: 10px 22px; background: #fff; color: #0f172a; font-size: .9375rem; font-weight: 600; border-radius: 8px; border: 1px solid #e2e8f0; transition: border-color .15s, background .15s; }
      .btn-outline:hover { border-color: #cbd5e1; background: #f8fafc; }
      .btn-purple { display: inline-flex; align-items: center; gap: 8px; padding: 10px 22px; background: #7c3aed; color: #fff; font-size: .9375rem; font-weight: 600; border-radius: 8px; transition: background .15s; }
      .btn-purple:hover { background: #6d28d9; }
      .hero-badges { margin-top: 32px; display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; }

      /* SECTIONS */
      .section { padding: 80px 0; border-bottom: 1px solid #f1f5f9; }
      .section-eyebrow { font-size: .75rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: #94a3b8; margin-bottom: 10px; }
      .section-heading { font-size: clamp(1.5rem, 3vw, 2.1rem); letter-spacing: -.03em; color: #0f172a; margin-bottom: 10px; }
      .section-sub { font-size: 1rem; color: #64748b; max-width: 480px; line-height: 1.65; }
      .text-center { text-align: center; }
      .mx-auto { margin-left: auto; margin-right: auto; }

      /* FEATURE GRID */
      .feature-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: #e2e8f0; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; margin-top: 48px; }
      .feature-item { background: #fff; padding: 28px; }
      .feature-icon { width: 34px; height: 34px; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; color: #2563eb; }
      .feature-name { font-size: .9375rem; font-weight: 600; color: #0f172a; margin-bottom: 6px; }
      .feature-desc { font-size: .875rem; color: #64748b; line-height: 1.6; }

      /* FRAMEWORK GRID */
      .fw-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 10px; margin-top: 40px; }
      .fw-card { display: flex; align-items: center; gap: 12px; padding: 14px 18px; border: 1px solid #e2e8f0; border-radius: 10px; background: #fff; font-size: .9rem; font-weight: 500; color: #334155; transition: border-color .15s, box-shadow .15s; }
      .fw-card:hover { border-color: #93c5fd; box-shadow: 0 2px 8px rgba(37,99,235,.08); color: #1e40af; }
      .fw-icon { width: 30px; height: 30px; border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

      /* DEMO */
      .demo-wrap { border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; margin-top: 40px; }
      .demo-header { padding: 12px 18px; background: #f8fafc; border-bottom: 1px solid #e2e8f0; display: flex; align-items: center; gap: 7px; font-size: .8rem; font-weight: 500; color: #64748b; }
      .demo-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
      .demo-body { padding: 28px; }

      /* ENTERPRISE */
      .ent-wrap { border: 1px solid #e2e8f0; border-radius: 16px; overflow: hidden; margin-top: 48px; display: grid; grid-template-columns: 1fr 1fr; }
      .ent-left { padding: 44px; background: #fff; border-right: 1px solid #e2e8f0; }
      .ent-right { padding: 44px; background: #0f172a; color: #fff; }
      .plan-badge { font-size: .7rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; margin-bottom: 14px; }
      .plan-badge-free { color: #64748b; }
      .plan-badge-ent { color: #a78bfa; }
      .plan-name { font-size: 1.4rem; font-weight: 700; margin-bottom: 14px; }
      .plan-price { font-size: 2.6rem; font-weight: 700; letter-spacing: -.04em; }
      .plan-period { font-size: .875rem; color: #94a3b8; margin: 6px 0 28px; }
      .plan-features { display: flex; flex-direction: column; gap: 10px; }
      .pf { display: flex; align-items: flex-start; gap: 9px; font-size: .875rem; line-height: 1.5; }
      .pf-check { flex-shrink: 0; margin-top: 2px; }
      .check-gray { color: #94a3b8; }
      .check-violet { color: #a78bfa; }
      .text-muted { color: #64748b; }
      .text-light { color: #e2e8f0; }
      .text-dim { color: #94a3b8; }
      .ent-cta { display: inline-flex; align-items: center; gap: 8px; margin-top: 32px; padding: 11px 22px; background: #7c3aed; color: #fff; font-size: .9375rem; font-weight: 600; border-radius: 8px; transition: background .15s; }
      .ent-cta:hover { background: #6d28d9; }
      .ent-note { margin-top: 10px; font-size: .8rem; color: #64748b; }

      /* BLOG */
      .blog-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 14px; margin-top: 40px; }
      .blog-card { padding: 22px; border: 1px solid #e2e8f0; border-radius: 10px; background: #fff; transition: border-color .15s, box-shadow .15s; }
      .blog-card:hover { border-color: #93c5fd; box-shadow: 0 2px 8px rgba(37,99,235,.08); }
      .blog-title { font-size: .9375rem; font-weight: 600; color: #0f172a; margin-bottom: 7px; line-height: 1.4; }
      .blog-desc { font-size: .8125rem; color: #64748b; line-height: 1.55; margin-bottom: 14px; }
      .blog-link { font-size: .8125rem; font-weight: 600; color: #2563eb; display: inline-flex; align-items: center; gap: 4px; }
      .all-posts { display: inline-flex; align-items: center; gap: 6px; font-size: .875rem; font-weight: 600; color: #2563eb; margin-top: 24px; transition: gap .15s; }
      .all-posts:hover { gap: 10px; }

      /* FAQ */
      details.faq { border: 1px solid #e2e8f0; border-radius: 8px; overflow: hidden; margin-bottom: 8px; }
      details.faq summary { padding: 17px 20px; font-size: .9375rem; font-weight: 600; cursor: pointer; display: flex; justify-content: space-between; align-items: center; list-style: none; color: #0f172a; user-select: none; }
      details.faq summary::-webkit-details-marker { display: none; }
      .faq-chev { transition: transform .2s; flex-shrink: 0; color: #94a3b8; }
      details[open] .faq-chev { transform: rotate(180deg); }
      .faq-body { padding: 0 20px 16px; font-size: .875rem; color: #475569; line-height: 1.65; border-top: 1px solid #f1f5f9; padding-top: 12px; }

      /* FOOTER */
      .footer { background: #0f172a; color: #94a3b8; padding: 56px 0 36px; }
      .footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 44px; }
      .footer-brand { display: flex; align-items: center; gap: 8px; font-weight: 700; font-size: 1rem; color: #fff; margin-bottom: 10px; }
      .footer-tagline { font-size: .8125rem; line-height: 1.6; }
      .footer-col-title { font-size: .8rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: #94a3b8; margin-bottom: 14px; }
      .footer-links { display: flex; flex-direction: column; gap: 9px; }
      .fl { font-size: .8125rem; color: #64748b; transition: color .15s; }
      .fl:hover { color: #94a3b8; }
      .fl-ent { font-size: .8125rem; color: #a78bfa; font-weight: 600; transition: color .15s; }
      .fl-ent:hover { color: #c4b5fd; }
      .footer-bottom { border-top: 1px solid #1e293b; padding-top: 22px; display: flex; justify-content: space-between; align-items: center; gap: 14px; flex-wrap: wrap; }
      .footer-copy { font-size: .8rem; color: #475569; }
      .footer-icons { display: flex; gap: 14px; }
      .fi { color: #475569; transition: color .15s; }
      .fi:hover { color: #94a3b8; }

      @media (max-width: 800px) {
        .ent-wrap { grid-template-columns: 1fr; }
        .ent-left { border-right: none; border-bottom: 1px solid #1e293b; }
        .footer-grid { grid-template-columns: 1fr 1fr; }
        .nav-link-ent { display: none; }
      }
      @media (max-width: 480px) {
        .footer-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>

  <body>

    <!-- NAV -->
    <nav class="nav">
      <div class="container nav-inner">
        <a href="/pompelmi/" class="nav-logo">
          <svg width="26" height="26" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <!-- Grapefruit: outer rind -->
            <circle cx="14" cy="14" r="14" fill="#F5B211"/>
            <!-- Pith ring -->
            <circle cx="14" cy="14" r="11" fill="#FAE3A2"/>
            <!-- Red flesh -->
            <circle cx="14" cy="14" r="9" fill="#E83A1D"/>
            <!-- 10 segments (5 lines through center) -->
            <line x1="14" y1="5" x2="14" y2="23" stroke="white" stroke-width="1.1"/>
            <line x1="19.3" y1="6.7" x2="8.7" y2="21.3" stroke="white" stroke-width="1.1"/>
            <line x1="22.6" y1="11.2" x2="5.4" y2="16.8" stroke="white" stroke-width="1.1"/>
            <line x1="22.6" y1="16.8" x2="5.4" y2="11.2" stroke="white" stroke-width="1.1"/>
            <line x1="19.3" y1="21.3" x2="8.7" y2="6.7" stroke="white" stroke-width="1.1"/>
            <!-- Center pip -->
            <circle cx="14" cy="14" r="1.8" fill="white"/>
          </svg>
          Pompelmi
        </a>
        <div class="nav-links">
          <a href="/pompelmi/getting-started/" class="nav-link">Docs</a>
          <a href="/pompelmi/blog/" class="nav-link">Blog</a>
          <a href="/pompelmi/enterprise/" class="nav-link-ent">Enterprise</a>
          <a href="https://github.com/pompelmi/pompelmi" target="_blank" rel="noopener" class="nav-gh">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <header class="hero">
      <div class="container">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          Open source · MIT · Node.js 18+
        </div>
        <h1 class="hero-title">File upload security<br/>that stays in your process</h1>
        <p class="hero-sub">Scan and block malicious uploads in Express, Next.js, NestJS, Fastify, and Koa. No cloud API. No daemon. One <code class="mono">npm install</code>.</p>
        <div class="hero-install mono">
          <span class="prompt">$</span>
          <span>npm install pompelmi</span>
          <button class="copy-btn" title="Copy" onclick="navigator.clipboard.writeText('npm install pompelmi')">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          </button>
        </div>
        <div class="hero-ctas">
          <a href="/pompelmi/getting-started/" class="btn-dark">
            Get started
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5-5 5m5-5H6"/></svg>
          </a>
          <a href="https://github.com/pompelmi/pompelmi" target="_blank" rel="noopener" class="btn-outline">
            <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            View on GitHub
          </a>
          <a href="/pompelmi/enterprise/" class="btn-purple">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Enterprise — $49.99/mo
          </a>
        </div>
        <div class="hero-badges">
          <a href="https://github.com/pompelmi/pompelmi" target="_blank" rel="noopener">
            <img src="https://img.shields.io/github/stars/pompelmi/pompelmi?style=flat-square&logo=github&color=e2e8f0&labelColor=f8fafc&logoColor=475569" alt="GitHub stars" loading="lazy" style="height:22px" />
          </a>
          <a href="https://www.npmjs.com/package/pompelmi" target="_blank" rel="noopener">
            <img src="https://img.shields.io/npm/v/pompelmi?style=flat-square&color=e2e8f0&labelColor=f8fafc" alt="npm version" loading="lazy" style="height:22px" />
          </a>
          <a href="https://www.npmjs.com/package/pompelmi" target="_blank" rel="noopener">
            <img src="https://img.shields.io/npm/dm/pompelmi?style=flat-square&color=e2e8f0&labelColor=f8fafc&label=downloads%2Fmo" alt="npm downloads" loading="lazy" style="height:22px" />
          </a>
          <a href="https://github.com/pompelmi/pompelmi/blob/main/LICENSE" target="_blank" rel="noopener">
            <img src="https://img.shields.io/github/license/pompelmi/pompelmi?style=flat-square&color=e2e8f0&labelColor=f8fafc" alt="MIT License" loading="lazy" style="height:22px" />
          </a>
        </div>
      </div>
    </header>

    <main>

      <!-- FEATURES -->
      <section class="section">
        <div class="container">
          <p class="section-eyebrow">How it works</p>
          <h2 class="section-heading">Six layers of protection in one call</h2>
          <p class="section-sub">Pass a Buffer, get a <code class="mono" style="font-size:.85em">clean | suspicious | malicious</code> verdict. Compose scanners, apply policies per endpoint, act immediately.</p>
          <div class="feature-grid">
            <div class="feature-item">

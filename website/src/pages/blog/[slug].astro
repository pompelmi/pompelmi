---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const BASE = 'https://pompelmi.github.io/pompelmi';

// Related posts: same tags, exclude self, up to 3
const allPosts = await getCollection('blog');
const postTags = new Set(post.data.tags ?? []);
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug && (p.data.tags ?? []).some((t) => postTags.has(t)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{post.data.title} — Pompelmi Blog</title>
    <meta name="description" content={post.data.description} />
    <link rel="canonical" href={`${BASE}/blog/${post.slug}/`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta property="og:title" content={post.data.title} />
    <meta property="og:description" content={post.data.description} />
    <meta property="og:url" content={`${BASE}/blog/${post.slug}/`} />
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={post.data.pubDate.toISOString()} />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" href="/pompelmi/favicon.svg" />
    
    <style>
      .prose {
        max-width: 65ch;
        color: #374151;
      }
      .prose h1 { font-size: 2.25rem; font-weight: 800; margin: 2rem 0 1rem; }
      .prose h2 { font-size: 1.875rem; font-weight: 700; margin: 1.75rem 0 0.875rem; }
      .prose h3 { font-size: 1.5rem; font-weight: 600; margin: 1.5rem 0 0.75rem; }
      .prose p { margin: 1rem 0; line-height: 1.75; }
      .prose ul, .prose ol { margin: 1rem 0; padding-left: 1.5rem; }
      .prose li { margin: 0.5rem 0; }
      .prose code { 
        background: #f3f4f6; 
        padding: 0.2rem 0.4rem; 
        border-radius: 0.25rem; 
        font-size: 0.875em; 
      }
      .prose pre { 
        background: #1f2937; 
        color: #f3f4f6; 
        padding: 1rem; 
        border-radius: 0.5rem; 
        overflow-x: auto; 
        margin: 1.5rem 0; 
      }
      .prose pre code { 
        background: transparent; 
        padding: 0; 
        color: inherit; 
      }
      .prose a { color: #2563eb; text-decoration: underline; }
      .prose a:hover { color: #1d4ed8; }
      .prose blockquote {
        border-left: 4px solid #e5e7eb;
        padding-left: 1rem;
        margin: 1.5rem 0;
        font-style: italic;
        color: #6b7280;
      }
      .prose hr {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin: 2rem 0;
      }
      .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.9em;
      }
      .prose thead { background: #f9fafb; }
      .prose th {
        text-align: left;
        padding: 0.625rem 0.875rem;
        font-weight: 600;
        border: 1px solid #e5e7eb;
        color: #111827;
      }
      .prose td {
        padding: 0.5rem 0.875rem;
        border: 1px solid #e5e7eb;
        vertical-align: top;
      }
      .prose tr:nth-child(even) td { background: #f9fafb; }
    </style>
  </head>

  <body class="antialiased bg-gray-50">
    <header class="bg-white border-b">
      <div class="mx-auto max-w-5xl px-4 py-6">
        <nav class="flex items-center justify-between">
          <a href="/pompelmi/" class="text-xl font-bold">Pompelmi</a>
          <div class="flex gap-4 text-sm">
            <a href="/pompelmi/" class="hover:underline">Home</a>
            <a href="/pompelmi/getting-started/" class="hover:underline">Docs</a>
            <a href="/pompelmi/blog/" class="font-medium hover:underline">Blog</a>
          </div>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-4 py-12">
      <article class="bg-white rounded-lg border p-8">
        <header class="mb-8 border-b pb-6">
          <h1 class="text-4xl font-bold mb-3">{post.data.title}</h1>
          <div class="text-sm text-gray-500">
            {post.data.pubDate.toLocaleDateString('en-US', { 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric' 
            })}
            {post.data.author && ` • ${post.data.author}`}
          </div>
          {post.data.tags && (
            <div class="flex flex-wrap gap-2 mt-4">
              {post.data.tags.map((tag) => (
                <span class="px-2 py-1 bg-gray-100 text-gray-700 text-xs rounded">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </header>

        <div class="prose">
          <Content />
        </div>
      </article>

      {relatedPosts.length > 0 && (
        <aside class="mt-12">
          <h2 class="text-xl font-bold mb-4 text-gray-800">Related posts</h2>
          <div class="grid gap-4 sm:grid-cols-3">
            {relatedPosts.map((rp) => (
              <a
                href={`/pompelmi/blog/${rp.slug}/`}
                class="block bg-white rounded-lg border p-4 hover:shadow-md transition-shadow hover:border-blue-300"
              >
                <p class="text-xs text-gray-400 mb-1">
                  {rp.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </p>
                <h3 class="font-semibold text-sm text-gray-800 hover:text-blue-600 leading-snug">
                  {rp.data.title}
                </h3>
              </a>
            ))}
          </div>
        </aside>
      )}

      <div class="mt-8 text-center">
        <a href="/pompelmi/blog/" class="text-blue-600 hover:underline">
          ← Back to Blog
        </a>
      </div>
    </main>

    <footer class="mt-16 border-t bg-white">
      <div class="mx-auto max-w-5xl px-4 py-8 text-center text-sm text-gray-600">
        <p>© {new Date().getFullYear()} Pompelmi. MIT License.</p>
      </div>
    </footer>
  </body>
</html>
